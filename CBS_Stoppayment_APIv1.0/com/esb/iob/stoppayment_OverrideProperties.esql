BROKER SCHEMA com.esb.iob


CREATE COMPUTE MODULE stoppayment_OverrideProperties
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		
		CALL CopyEntireMessage();
		SET OutputLocalEnvironment.TCPIP.Receive.Type 		= 'Client';
		SET OutputLocalEnvironment.TCPIP.Receive.Hostname 	= '172.26.100.197';
		SET OutputLocalEnvironment.TCPIP.Receive.Port 		= '14401';
		RETURN TRUE;
	END;
	CREATE PROCEDURE CopyEntireMessage() BEGIN
		SET OutputRoot = InputRoot;
	END;
END MODULE;
		