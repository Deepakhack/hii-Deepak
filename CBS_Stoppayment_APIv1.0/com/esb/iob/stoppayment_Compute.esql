BROKER SCHEMA com.esb.iob


CREATE COMPUTE MODULE stoppayment_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE ev REFERENCE TO Environment.variables;
		UPDATE Database.STOP_PAYMENT_SESSION AS II SET FLAG = 'F' WHERE II.requestid = ev.requestid  AND II.sessionid = ev.sessionid;
		COMMIT;
		RETURN TRUE;
	END;
END MODULE;
