BROKER SCHEMA com.dee.Fun


CREATE COMPUTE MODULE JTest_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
	
	
	DECLARE ev REFERENCE To Environment.Variables;
	SET ev.data=createJsonResponse();
	SET ev.resp=ev.data;
	SET OutputRoot=ev.resp;
	
	
		RETURN TRUE;
	END;
END MODULE;


CREATE PROCEDURE createJsonResponse()
RETURNS CHARACTER
LANGUAGE JAVA
EXTERNAL NAME "ok.com.dee.JsonResponseCreator1.createJsonResponse";