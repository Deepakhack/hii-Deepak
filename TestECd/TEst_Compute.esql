





CREATE COMPUTE MODULE TEst_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE ev REFERENCE To Environment.Variables;
		DECLARE Curve CHARACTER 'X25519';
		-- DECLARE clientPublicKey CHARACTER '-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----';
		-- DECLARE clientNonce CHARACTER 'iVi/XwjBZwXpYO+qhf/Uy5h3psLbDKhyIyFssQfh1aI=';
		-- DECLARE expiry CHARACTER '2025-10-24T11:17:58.413+00:00';
		-- DECLARE data CHARACTER 'dddd';
		DECLARE key CHARACTER '';
		SET ev.DecryptedResponse=JWEEncrpyt(InputRoot.BLOB.BLOB,key);
		SET OutputRoot.BLOB.BLOB=ev.DecryptedResponse;

		RETURN TRUE;
	END;


END MODULE;
